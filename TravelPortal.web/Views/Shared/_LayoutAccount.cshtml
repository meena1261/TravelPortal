
<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Meta Tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Silvi Travel</title>

    <meta name="description" content="">
    <meta name="keywords" content="travel booking">
    <!-- Favicon -->
    <link href="~/Content/agent/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Main.css -->
    <link rel="stylesheet" href="~/Content/agent/css/meanmenu.css">

    <!-- Tabler Icon CSS -->
    <link rel="stylesheet" href="~/Content/agent/plugins/tabler-icons/tabler-icons.css">

    <!-- Fontawesome Icon CSS -->
    <link rel="stylesheet" href="~/Content/agent/plugins/fontawesome/css/fontawesome.min.css">
    <link rel="stylesheet" href="~/Content/agent/plugins/fontawesome/css/all.min.css">

    <!-- Owlcarousel CSS -->
    <link rel="stylesheet" href="~/Content/agent/plugins/owlcarousel/owl.carousel.min.css">

    <!-- Rangeslider CSS -->
    <link rel="stylesheet" href="~/Content/agent/plugins/ion-rangeslider/css/ion.rangeSlider.css">
    <link rel="stylesheet" href="~/Content/agent/plugins/ion-rangeslider/css/ion.rangeSlider.min.css">

    <!-- Iconsax CSS -->
    <link rel="stylesheet" href="~/Content/agent/css/iconsax.css">

    <!-- Datepicker CSS -->
    <link rel="stylesheet" href="~/Content/agent/css/bootstrap-datetimepicker.min.css">

    <!-- Style CSS -->
    <link rel="stylesheet" href="~/Content/agent/css/style.css">

</head>
<body class="bg-light-200">

    <!-- Main Wrapper -->
    <div class="main-wrapper authentication-wrapper">
        <div class="container-fuild">
            <div class="w-100 overflow-hidden position-relative flex-wrap d-block vh-100">
                <div class="row justify-content-center align-items-center vh-100 overflow-auto flex-wrap ">
                    <div class="col-xxl-4 col-lg-6 col-md-6 col-11 mx-auto">
                        <div class="p-4 text-center">
                            <img src="~/Content/logo/logo.png" alt="logo" class="img-fluid w-25" />
                        </div>

                        @RenderBody()
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- /Main Wrapper -->
    <!-- Cursor -->
    <div class="xb-cursor tx-js-cursor">
        <div class="xb-cursor-wrapper">
            <div class="xb-cursor--follower xb-js-follower"></div>
        </div>
    </div>
    <!-- /Cursor -->
    <!-- Jquery JS -->
    <script src="~/agent-assets/js/jquery-3.7.1.min.js" type="text/javascript"></script>

    <!-- Bootstrap JS -->
    <script src="~/agent-assets/js/bootstrap.bundle.min.js" type="text/javascript"></script>

    <!-- Wow JS -->
    <script src="~/agent-assets/js/wow.min.js" type="text/javascript"></script>

    <!-- MeanMenu Js -->
    <script src="~/agent-assets/js/jquery.meanmenu.min.js" type="text/javascript"></script>

    <!-- Datepicker Core JS -->
    <script src="~/Content/agent/plugins/moment/moment.js" type="text/javascript"></script>
    <script src="~/agent-assets/js/bootstrap-datetimepicker.min.js" type="text/javascript"></script>

    <!-- cursor JS -->
    <script src="~/agent-assets/js/cursor.js" type="text/javascript"></script>

    <!-- Script JS -->
    <script src="~/agent-assets/js/script.js" type="text/javascript"></script>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/jqueryval")
</body>
</html>