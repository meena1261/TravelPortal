@model TravelPortal.web.Models.RegisterViewModel
@{
    Layout = "~/Views/Shared/_LayoutAccount.cshtml";
    ViewBag.Title = "Register";
}

<div class="card authentication-card">
    <div class="card-header">
        <div class="text-center">
            @if (Model.PageIndex == 4)
            {
                <h5 class="mb-1">Congratulations</h5>
            }
            else
            {
                <h5 class="mb-1">Sign Up</h5>
            }
        </div>
    </div>
    <div class="card-body">
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @using (Html.BeginForm("Register", "Account", new { }, FormMethod.Post, new { role = "form" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="PageIndex" value="@Model.PageIndex" />
            if (Model.PageIndex == 1)
            {
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <div class="input-icon">
                        <span class="input-icon-addon">
                            <i class="isax isax-user"></i>
                        </span>
                        @Html.TextBoxFor(m => m.FullName, new { @class = "form-control form-control-lg", @placeholder = "Enter Full name", data_val = "true", data_val_required = "required" })
                    </div>
                    @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger" })
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <div class="input-icon">
                        <span class="input-icon-addon">
                            <i class="isax isax-message"></i>
                        </span>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg", @placeholder = "Enter Email", data_val = "true", data_val_required = "required", data_val_email = "The Email field is not a valid e-mail address." })
                    </div>
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>
                <div class="mt-3 mb-3">
                    <div class="d-flex">
                        <div class="form-check d-flex align-items-center mb-2">
                            <input class="form-check-input mt-0" type="checkbox" value="" id="agree">
                            <label class="form-check-label ms-2 text-gray-9 fs-14" for="agree">
                                I agree with the <a href="terms-conditions.html" class="link-primary fw-medium">Terms Of Service.</a>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <button type="submit" class="btn btn-xl btn-primary d-flex align-items-center justify-content-center w-100">Register<i class="isax isax-arrow-right-3 ms-2"></i></button>
                </div>
                <div class="login-or mb-3">
                    <span class="span-or">Or</span>
                </div>
                <div class="d-flex justify-content-center">
                    <p class="fs-14">Already have an account? @Html.ActionLink("Sign In", "Login", "Account", null, new { @class = "link-primary fw-medium" }) </p>
                </div>
            }
            else if (Model.PageIndex == 2)
            {
                @Html.HiddenFor(m => m.FullName)
                @Html.HiddenFor(m => m.Email)
                <div class="mb-3">
                    <label class="form-label">OTP</label>
                    <div class="input-icon">
                        <span class="input-icon-addon">
                            <i class="isax isax-verify"></i>
                        </span>
                        @Html.TextBoxFor(m => m.OTP, new { @class = "form-control form-control-lg", @placeholder = "Enter OTP", data_val = "true", data_val_required = "required" })
                    </div>
                    <a href="#" class="w-100 text-right">Resend OTP ?</a>
                    <br />
                    @Html.ValidationMessageFor(m => m.OTP, "", new { @class = "text-danger" })
                </div>
                <label class="text-success mb-3">OTP Successfully Sent !</label>
                <div class="mb-3">
                    <button type="submit" class="btn btn-xl btn-primary d-flex align-items-center justify-content-center w-100">Register<i class="isax isax-arrow-right-3 ms-2"></i></button>
                </div>
            }
            else if (Model.PageIndex == 3)
            {
                @Html.HiddenFor(m => m.FullName)
                @Html.HiddenFor(m => m.Email)
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <div class="input-icon">
                        <span class="input-icon-addon">
                            <i class="isax isax-lock"></i>
                        </span>
                        @Html.TextBoxFor(m => m.Password, new { @class = "form-control form-control-lg pass-input", @placeholder = "Enter Password", data_val = "true", data_val_required = "required" })
                        <span class="input-icon-addon toggle-password">
                            <i class="isax isax-eye-slash"></i>
                        </span>
                    </div>
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>
                <div class="mb-3">
                    <label class="form-label">Confirm Password</label>
                    <div class="input-icon">
                        <span class="input-icon-addon">
                            <i class="isax isax-lock"></i>
                        </span>
                        @Html.TextBoxFor(m => m.ConfirmPassword, new { @class = "form-control form-control-lg pass-input", @placeholder = "Enter Password", data_val = "true", data_val_required = "required" })
                        <span class="input-icon-addon toggle-password">
                            <i class="isax isax-eye-slash"></i>
                        </span>
                    </div>
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                </div>
                <div class="mb-3">
                    <button type="submit" class="btn btn-xl btn-primary d-flex align-items-center justify-content-center w-100">Register<i class="isax isax-arrow-right-3 ms-2"></i></button>
                </div>
            }
            else if (Model.PageIndex == 4)
            {
                <div class="mb-3 text-center">
                    <img src="~/Content/icon/success.png" class="mb-3" style="width:100px;" />
                    <h6 class="text-success mb-3">Your Account has been successfully created</h6>
                    <a href="@RouteConfig.AgentLogin.ToPrefixApplicationURL()" class="btn btn-success">Continue</a>
                </div>
            }

        }
    </div>
</div>