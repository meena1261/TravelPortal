
<!DOCTYPE html>
<html lang="en" data-layout-mode="light_mode">
<head>

    <!-- Meta Tags -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Silvi - @ViewBag.Title </title>
    <!-- Favicon -->
    <link rel="shortcut icon" type="image/x-icon" href="~/Content/admin/img/favicon.png">

    <!-- Apple Touch Icon -->
    <link rel="apple-touch-icon" sizes="180x180" href="~/Content/admin/img/apple-touch-icon.png">


    @Styles.Render("~/admin/admincss")
    @Styles.Render("~/admin/css/plugins")
</head>

<body>
    <div id="global-loader">
        <div class="whirly-loader"> </div>
    </div>
    <div class="loader-container" id="divloader" style="display:none;">
        <span class="ajax-loader"></span>
    </div>
    <!-- Main Wrapper -->
    <div class="main-wrapper">

        <!-- Header -->
        <div class="header">
            <div class="main-header">

                <!-- Logo -->
                <div class="header-left active">
                    <a href="@Url.Action("Dashboard","Admin")" class="logo logo-normal">
                        <img src="~/Content/logo/logo.png" />
                    </a>
                    <a href="@Url.Action("Dashboard","Admin")" class="logo logo-white">
                        <img src="~/Content/logo/logo.png" />
                    </a>
                    <a href="@Url.Action("Dashboard","Admin")" class="logo-small">
                        <img src="~/Content/logo/logo.png" />
                    </a>
                </div>
                <!-- /Logo -->

                <a id="mobile_btn" class="mobile_btn" href="#sidebar">
                    <span class="bar-icon">
                        <span></span>
                        <span></span>
                        <span></span>
                    </span>
                </a>

                <!-- Header Menu -->
                <ul class="nav user-menu">

                    <!-- Search -->
                    <li class="nav-item nav-searchinputs">
                        <div class="top-nav-search">
                            <a href="javascript:void(0);" class="responsive-search">
                                <i class="fa fa-search"></i>
                            </a>
                            <form action="#" class="dropdown">
                                <div class="searchinputs input-group dropdown-toggle" id="dropdownMenuClickable" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                    <input type="text" placeholder="Search">
                                    <div class="search-addon">
                                        <span><i class="ti ti-search"></i></span>
                                    </div>
                                    <span class="input-group-text">
                                        <kbd class="d-flex align-items-center"><img src="~/Content/admin/img/icons/command.svg" alt="img" class="me-1">K</kbd>
                                    </span>
                                </div>
                                <div class="dropdown-menu search-dropdown" aria-labelledby="dropdownMenuClickable">
                                    <div class="search-info">
                                        <h6>
                                            <span><i data-feather="search" class="feather-16"></i></span>Recent Searches
                                        </h6>
                                        <ul class="search-tags">
                                            <li><a href="javascript:void(0);">Products</a></li>
                                            <li><a href="javascript:void(0);">Sales</a></li>
                                            <li><a href="javascript:void(0);">Applications</a></li>
                                        </ul>
                                    </div>
                                    <div class="search-info">
                                        <h6><span><i data-feather="help-circle" class="feather-16"></i></span>Help</h6>
                                        <p>How to Change Product Volume from 0 to 200 on Inventory management</p>
                                        <p>Change Product Name</p>
                                    </div>
                                    <div class="search-info">
                                        <h6><span><i data-feather="user" class="feather-16"></i></span>Customers</h6>
                                        <ul class="customers">
                                            <li><a href="javascript:void(0);">Aron Varu<img src="~/Content/admin/img/profiles/avator1.jpg" alt="Img" class="img-fluid"></a></li>
                                            <li><a href="javascript:void(0);">Jonita<img src="~/Content/admin/img/profiles/avatar-01.jpg" alt="Img" class="img-fluid"></a></li>
                                            <li><a href="javascript:void(0);">Aaron<img src="~/Content/admin/img/profiles/avatar-10.jpg" alt="Img" class="img-fluid"></a></li>
                                        </ul>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </li>
                    <!-- /Search -->
                    <li class="nav-item dropdown link-nav">
                        <a href="javascript:void(0);" class="btn btn-primary btn-md d-inline-flex align-items-center" data-bs-toggle="dropdown">
                            <i class="ti ti-circle-plus me-1"></i>Add New
                        </a>
                        <div class="dropdown-menu dropdown-xl dropdown-menu-center">
                            <div class="row g-2">
                                <div class="col-md-2">
                                    <a href="javascript:void(0);" class="link-item">
                                        <span class="link-icon">
                                            <i class="ti ti-brand-codepen"></i>
                                        </span>
                                        <p>New Agent</p>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </li>


                    <!-- Flag -->
                    <li class="nav-item dropdown has-arrow flag-nav nav-item-box">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="javascript:void(0);"
                           role="button">
                            <img src="~/Content/admin/img/flags/us-flag.svg" alt="Language" class="img-fluid">
                        </a>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a href="javascript:void(0);" class="dropdown-item">
                                <img src="~/Content/admin/img/flags/english.svg" alt="Img" height="16">English
                            </a>
                            <a href="javascript:void(0);" class="dropdown-item">
                                <img src="~/Content/admin/img/flags/arabic.svg" alt="Img" height="16">Arabic
                            </a>
                        </div>
                    </li>
                    <!-- /Flag -->

                    <li class="nav-item nav-item-box">
                        <a href="javascript:void(0);" id="btnFullscreen">
                            <i class="ti ti-maximize"></i>
                        </a>
                    </li>
                    <li class="nav-item nav-item-box">
                        <a href="javascript:void(0);">
                            <i class="ti ti-mail"></i>
                            <span class="badge rounded-pill">1</span>
                        </a>
                    </li>
                    <!-- Notifications -->
                    <li class="nav-item dropdown nav-item-box">
                        <a href="javascript:void(0);" class="dropdown-toggle nav-link" data-bs-toggle="dropdown">
                            <i class="ti ti-bell"></i>
                        </a>
                        <div class="dropdown-menu notifications">
                            <div class="topnav-dropdown-header">
                                <h5 class="notification-title">Notifications</h5>
                                <a href="javascript:void(0)" class="clear-noti">Mark all as read</a>
                            </div>
                            <div class="noti-content">
                                <ul class="notification-list">
                                    <li class="notification-message">
                                        <a href="javascript:void(0);">
                                            <div class="media d-flex">
                                                <span class="avatar flex-shrink-0">
                                                    <img alt="Img" src="~/Content/admin/img/profiles/avatar-13.jpg">
                                                </span>
                                                <div class="flex-grow-1">
                                                    <p class="noti-details"><span class="noti-title">James Kirwin</span> confirmed his order.  Order No: #78901.Estimated delivery: 2 days</p>
                                                    <p class="noti-time">4 mins ago</p>
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                            <div class="topnav-dropdown-footer d-flex align-items-center gap-3">
                                <a href="#" class="btn btn-secondary btn-md w-100">Cancel</a>
                                <a href="javascript:void(0);" class="btn btn-primary btn-md w-100">View all</a>
                            </div>
                        </div>
                    </li>
                    <!-- /Notifications -->

                    <li class="nav-item nav-item-box">
                        <a href="javascript:void(0);"><i class="ti ti-settings"></i></a>
                    </li>
                    <li class="nav-item dropdown has-arrow main-drop profile-nav">
                        <a href="javascript:void(0);" class="nav-link userset" data-bs-toggle="dropdown">
                            <span class="user-info p-0">
                                <span class="user-letter">
                                    <img src="~/Content/admin/img/profiles/avator1.jpg" alt="Img" class="img-fluid">
                                </span>
                            </span>
                        </a>
                        <div class="dropdown-menu menu-drop-user">
                            <div class="profileset d-flex align-items-center">
                                <span class="user-img me-2">
                                    <img src="~/Content/admin/img/profiles/avator1.jpg" alt="Img">
                                </span>
                                <div>
                                    <h6 class="fw-medium">John Smilga</h6>
                                    <p>Admin</p>
                                </div>
                            </div>
                            <a class="dropdown-item" href="#"><i class="ti ti-user-circle me-2"></i>MyProfile</a>
                            <a class="dropdown-item" href="#"><i class="ti ti-file-text me-2"></i>Reports</a>
                            <a class="dropdown-item" href="#"><i class="ti ti-settings-2 me-2"></i>Settings</a>
                            <hr class="my-2">
                            @using (Html.BeginForm("LogoutAdmin", "Account", FormMethod.Post, new { id = "logoutForm", @class = "navbar-right" }))
                            {
                                @Html.AntiForgeryToken()
                                <a class="dropdown-item logout pb-0" href="javascript:document.getElementById('logoutForm').submit()"><i class="ti ti-logout me-2"></i>Logout</a>}
                        </div>
                    </li>
                </ul>
                <!-- /Header Menu -->
                <!-- Mobile Menu -->
                <div class="dropdown mobile-user-menu">
                    <a href="javascript:void(0);" class="nav-link dropdown-toggle" data-bs-toggle="dropdown"
                       aria-expanded="false"><i class="fa fa-ellipsis-v"></i></a>
                    <div class="dropdown-menu dropdown-menu-right">
                        <a class="dropdown-item" href="javascript:void(0);">My Profile</a>
                        <a class="dropdown-item" href="javascript:void(0);">Settings</a>
                        <a class="dropdown-item" href="javascript:void(0);">Logout</a>
                    </div>
                </div>
                <!-- /Mobile Menu -->
            </div>
        </div>
        <!-- /Header -->
        <!-- Sidebar -->
        @Html.Action("SideMenu", "Admin")
        <!-- /Sidebar -->

        <div class="page-wrapper">
            <div class="content">
                @RenderBody()
                <div id="divAddEdit"></div>
            </div>

            <div class="copyright-footer d-flex align-items-center justify-content-between border-top bg-white gap-3 flex-wrap">
                <p class="fs-13 text-gray-9 mb-0">2014 - 2025 &copy; DreamsPOS. All Right Reserved</p>
                <p>Designed & Developed By <a href="javascript:void(0);" class="link-primary">Dreams</a></p>
            </div>
        </div>

    </div>
    <!-- /Main Wrapper -->
    <!-- Delete Modal -->
    <div class="modal fade modal-default" id="delete_comman_modal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body p-0">
                    <div class="success-wrap text-center">
                        <form action="" data-ajax="true" data-ajax-begin="fnStartLoader" data-ajax-complete="fnStopLoader" data-ajax-failure="fnDeleteFailure" data-ajax-method="GET" data-ajax-success="fnDeleteSuccess" enctype="multipart/form-data" id="frmDeleteItem" method="GET" novalidate="novalidate">
                            <div class="icon-success bg-danger-transparent text-danger mb-2">
                                <i class="ti ti-trash"></i>
                            </div>
                            <h3 class="mb-2">Delete </h3>
                            <p class="fs-16 mb-3">Are you sure you want to delete this?</p>
                            <div class="d-flex align-items-center justify-content-center gap-2 flex-wrap">
                                <button type="submit" class="btn btn-md btn-primary">Yes, Delete</button>
                                <button type="button" class="btn btn-md btn-secondary" data-bs-dismiss="modal">No, Cancel</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- End Delete Modal -->

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/jqueryval")
    @Scripts.Render("~/bundles/admin/js")
    @Scripts.Render("~/bundles/admin/plugins")
<script src="~/Scripts/admin/custom.js"></script>
    <script type="text/javascript">
        function fnDeleteSuccess(response, status, xhr) {
            // Try to detect content type
            const contentType = xhr.getResponseHeader("Content-Type");

            if (contentType && contentType.indexOf("application/json") !== -1) {
                // JSON response
                if (response.status > 0) {
                    $('#delete_comman_modal').modal('hide');
                    fnStartLoader();
                    location.reload();
                    // Optionally update a section manually
                    //$('#divlist').load('/YourController/GetUpdatedList');
                } else {
                    alert(response.message);
                }
            } else {
                // Assume HTML / Partial View
                $('#divlist').html(response); // Inject the returned HTML
                $('#delete_comman_modal').modal('hide');
            }
        }

        function fnDeleteFailure(xhr, status, error) {
            alert("Error: " + error);
        }
        function fnStartLoader() {
            $("#divloader").css("display", "flex");
        }
        function fnStopLoader() {
            $(document).ready(function () {
                setTimeout(function () {
                    $("#divloader").hide(); // Hide loader after 2 seconds
                }, 500);
            });
        }
    </script>
    <script>

        $(document).ajaxStart(function () {
            $("#btndisabled").show();
            $("#btnContinue").hide();
        });
        $(document).ajaxStop(function () {
            $("#btndisabled").hide();
            $("#btnContinue").show();
        });
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>