<div class="modal fade modal-default" id="mail_send_comman_modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body p-0">
                <div class="success-wrap text-center">

                    <div class="icon-success bg-success-transparent text-success mb-2">
                        <i class="ti ti-check-box"></i>
                    </div>
                    <h3 class="mb-2">Mail Sent Successfully </h3>
                    <p class="fs-16 mb-3">Account Activation Mail Sent !</p>
                    <div class="d-flex align-items-center justify-content-center gap-2 flex-wrap">
                        <button type="button" class="btn btn-md btn-secondary" data-bs-dismiss="modal">Ok</button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

