@model PasswordResetByAdminModel
<div class="card">
    <div class="card-header">
        @using (Ajax.BeginForm("ResetUserPassword", "Admin", null, new AjaxOptions { HttpMethod = "POST", OnSuccess = "fn_Success", OnFailure = "fn_Failure", OnBegin = "fnStartLoader", OnComplete = "fnStopLoader" }, new { enctype = "multipart/form-data" }))
        {
            <div class="row">
                <div class="col-md-3">

                    <div class="form-group">
                        <label class="text-dark mb-1">Select Agent</label>
                        @Html.DropDownListFor(m => m.Id, (IEnumerable<SelectListItem>)ViewBag.agentlist, "-- Select --", new { @class = "js-example-basic-single select2", onchange = "$('.hideshow').show()" })
                    </div>
                    @Html.ValidationMessageFor(model => model.Id, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-3 hideshow" style="display:none;">
                    <div class="form-group">
                        <label class="text-dark mb-1">Password</label>
                        @Html.TextBoxFor(m => m.Password, new { @class = "form-control mb-2", @data_val = "true", @data_val_required = "Required" })
                    </div>
                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-3 hideshow" style="display:none;">
                    <br />
                    <button type="submit" class="btn btn-primary mt-1">Submit</button>
                </div>
            </div>
        }
    </div>
</div>

@Scripts.Render("~/bundles/jqueryval")
<script>
    function fn_Success(d) {
        if (d.status > 0) {
            Swal.fire({
                title: "Successfully",
                text: d.message,
                icon: "success"
            }).then((result) => {
                if (result.isConfirmed) {
                    location.reload();
                }
            });
        } else {
            $.toast({
                heading: 'Message',
                text: d.message,
                position: 'top-right',
                showHideTransition: 'fade',
                icon: 'error'
            });
        }
    }
    function fn_Failure(d) {
        $.toast({
            heading: 'Message',
            text: 'failed',
            position: 'top-right',
            showHideTransition: 'fade',
            icon: 'error'
        });
    }
</script>