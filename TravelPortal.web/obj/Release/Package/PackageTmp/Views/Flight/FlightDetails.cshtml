                <div class="card-header d-flex justify-content-between">
                    <h6 class="card-title">ADULT (12 yrs+)</h6>
                    <div>
                        <span class="me-1" id="spnadultCount">0</span>
                        <span class="me-1">/</span>
                        <span class="me-1">@objfareSummary.Adult</span>
                        <span class="me-1">added</span>
                    </div>
                </div>
