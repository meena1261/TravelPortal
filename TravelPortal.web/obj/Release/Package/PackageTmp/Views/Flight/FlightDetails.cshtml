                    <!-- Traveller List -->
                    <div id="adultdiv" data-prefix="Adults">
                        @for (int ad = 0; ad < Model.Adults.Count; ad++)
                        {
                            <div class="traveller-item traveller-card border p-3 mb-3">
                                <div class="d-flex align-items-center mb-2">
                                    <input class="form-check-input me-2" name="adult" value="adult" type="checkbox">
                                    <strong>ADULT 1</strong>
                                </div>

                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label">First & Middle Name</label>
                                        @Html.TextBoxFor(m => m.Adults[ad].FirstName, new { @class = "form-control", @data_val = "true", @data_val_required = "Required", @placeholder = "First & Middle Name" })
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Last Name</label>
                                        @Html.TextBoxFor(m => m.Adults[ad].LastName, new { @class = "form-control", @placeholder = "Last Name" })
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Gender</label>
                                        @Html.DropDownListFor(m => m.Adults[ad].Gender, DropdownLists.Gender(), "-- Select --", new { @class = "form-control" })
                                    </div>
                                </div>
                                <div class="row g-2 mb-2">

                                    <div class="col-md-4">
                                        <label class="form-label">Date of birth</label>
                                        @Html.TextBoxFor(m => m.Adults[ad].DOB, new { @type = "date", @class = "form-control" })
                                    </div>
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label">Country Code</label>
                                        @Html.DropDownListFor(m => m.Adults[ad].CountryCode, ViewBag.Country as List<SelectListItem>, "-- Select --", new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Mobile</label>
                                        @Html.TextBoxFor(m => m.Adults[ad].Mobile, new { @class = "form-control", @placeholder = "Mobile No (Optional)" })
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Email</label>
                                        @Html.TextBoxFor(m => m.Adults[ad].Email, new { @class = "form-control", @placeholder = "Email (Optional)" })
                                    </div>
                                </div>

                                <div class="form-check mt-2">
                                    <input class="form-check-input" name="IsHasFrequentFlyerNumber" type="checkbox" id="ff1">
                                    <label class="form-check-label" for="ff1">
                                        Frequent Flyer Number <small>(Avail extra benefits & earn points)</small>
                                    </label>
                                </div>

                                <div class="row g-2 mt-1">
                                    <div class="col-md-6">
                                        <label class="form-label">Frequent Flyer Airline</label>

                                        @Html.TextBoxFor(m => m.Adults[ad].FrequentFlyerAirline, new { @class = "form-control", @placeholder = "Frequent Flyer Airline" })

                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Frequent Flyer No</label>
                                        @Html.TextBoxFor(m => m.Adults[ad].FrequentFlyerNo, new { @class = "form-control", @placeholder = "Frequent Flyer No" })
                                    </div>
                                </div>

                                <div class="form-check mt-3">
                                    @Html.CheckBoxFor(m => m.Adults[ad].IsRequiredWheelChair, new { @class = "form-check-input" })
                                    <label class="form-check-label" for="wheel1">I require wheelchair (Optional)</label>
                                </div>
                            </div>
                        }
