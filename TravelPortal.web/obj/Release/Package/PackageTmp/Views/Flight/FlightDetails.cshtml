@model TravelPortal.web.Models.CreateOrderPNRModel
@{
    var result = ViewBag.flightinfo as TravelPortal.web.Models.ViewModel.FlightInfoVM;

    var objfareSummary = result.flightSummary;

    string walletBalance = ViewBag.walletBalance;
    string CreditLimit = ViewBag.CreditLimit;


}

<style>
    .flight-card {
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        padding: 16px;
        box-shadow: 0 1px 5px rgba(0,0,0,0.1);
    }

    .flight-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #eee;
        padding-bottom: 8px;
    }

    .flight-time {
        font-weight: 600;
        font-size: 1.1rem;
    }

    .flight-detail {
        margin-left: 24px;
    }

    .bag-icon {
        color: #f4b400;
    }

    .tag {
        background-color: #e9f7ef;
        color: #28a745;
        font-size: 0.8rem;
        padding: 2px 8px;
        border-radius: 4px;
        font-weight: 500;
    }

    .traveller-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 16px;
        margin-top: 15px;
        background: #fff;
    }

    .section-header {
        font-weight: 600;
        background: #f8f9fa;
        padding: 8px 12px;
        border-radius: 6px;
        margin-bottom: 10px;
    }

    .info-text {
        font-size: 0.85rem;
        color: #666;
    }

    .plane {
        margin: 30px auto;
        background: #fff;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        width: 80%;
        max-width: 700px;
    }

    .seat-row {
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 6px 0;
    }

    .seat {
        width: 30px;
        height: 30px;
        background: #e0e0e0;
        margin: 3px;
        border-radius: 4px;
        cursor: pointer;
        text-align: center;
        line-height: 30px;
        font-size: 12px;
        transition: all 0.2s ease;
    }

        .seat:hover {
            background: #b3e5fc;
        }

        .seat.selected {
            background: #2196f3;
            color: white;
        }

        .seat.reserved {
            background: #9e9e9e;
            cursor: not-allowed;
        }

    .aisle {
        width: 30px;
    }

    .legend {
        margin-top: 15px;
    }

        .legend span {
            display: inline-block;
            width: 20px;
            height: 20px;
            margin-right: 5px;
            border-radius: 3px;
        }

    .legend-item {
        margin-right: 15px;
    }

    .input-validation-error {
        border-color: orangered;
    }
</style>
<div class="container">
    @using (Ajax.BeginForm("CreateOrderPNR", "Flight", new { crId = result.CacheKey }, new AjaxOptions { HttpMethod = "POST", OnSuccess = "fn_Success", OnFailure = "fn_Failure", OnBegin = "", OnComplete = "" }, new { id = "frmCreateOrderPNR", onsubmit = "return onSubmit();", enctype = "multipart/form-data" }))
    {
        
    <input type="hidden" name="tripType" value="Oneway" />

        <div class="row">
            <div class="col-md-9">
                @FlightDetail(result)

                @Passangers(objfareSummary)

            </div>
            @FareSummary(objfareSummary)
        </div>
    }
</div>

@helper FlightDetail(TravelPortal.web.Models.ViewModel.FlightInfoVM result)
{
    string offerId = string.Empty;
    <div class="card">
        <div class="card-body">
            @if (result != null && result.flightItineraries.Count > 0)
            {
                foreach (var item in result.flightItineraries)
                {
                    offerId += item.offerId;
                    int segCount = 1;
                    <div class="flight-card bg-white mt-2">
                        <div class="flight-header">
                            <div>
                                <h5 class="mb-0 fw-bold text-dark">@item.FromCity → @item.ToCity</h5>
                                <small class="text-muted"><span class="badge bg-primary"> @item.TravelDate </span> @(item.Stops > 0 ? $". {item.Stops} Stops" : "") · @item.Duration</small>
                            </div>
                            <div>
                                <span class="tag">CANCELLATION FEES APPLY</span>
                            </div>
                        </div>

                        @foreach (var segments in item.segments)
                        {

                            <div class="d-flex align-items-center justify-content-between mt-3">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="@segments.AirlineLogo" alt="@segments.AirlineName" width="40">
                                    <div>
                                        <strong>@segments.AirlineName</strong> <small>@segments.AirlineCode @segments.FlightNumber</small>
                                        <br>
                                        <span class="badge text-bg-light border">@segments.AirCraftCode</span>
                                        <small>@segments.CabinClass -> @segments.CabinClassType</small>
                                    </div>
                                </div>
                                <div>
                                    <a href="#" data-bs-toggle="modal" data-bs-target="#fare-rule-@segCount" class="btn btn-primary btn-xs mb-1">Fare Rules</a>
                                </div>
                            </div>

                            <div class="mt-3">
                                <div class="d-flex">
                                    <div style="width:80px;">
                                        <div class="flight-time">@segments.DepatureTime</div>

                                    </div>
                                    <div class="flight-detail flex-grow-1">
                                        <b class="text-dark">@segments.FromCity</b>
                                        <br />
                                        <small>@segments.FromAirport, @(!string.IsNullOrEmpty(segments.DepartureTerminal) ? $"Terminal-{segments.DepartureTerminal}" : "")</small>
                                        @*<div class="text-muted small">2h 55m</div>*@
                                    </div>
                                </div>
                                <div>
                                    <h6>
                                        @segments.Duration
                                    </h6>
                                </div>
                                <div class="d-flex mt-2">
                                    <div style="width:80px;">
                                        <div class="flight-time">@segments.ArrivalTime</div>
                                    </div>
                                    <div class="flight-detail flex-grow-1">
                                        <b class="text-dark">@segments.ToCity</b>
                                        <br />
                                        <small>@segments.ToAirport, @(!string.IsNullOrEmpty(segments.ArrivalTerminal) ? $"Terminal-{segments.ArrivalTerminal}" : "")</small>
                                    </div>
                                </div>
                            </div>

                            <hr>

                            <div class="d-flex justify-content-between">
                                <div><i class="ti ti-luggage bag-icon"></i> Cabin Baggage: <strong>@segments.CabinBaggage.weight @segments.CabinBaggage.weightUnit / Adult</strong></div>
                                <div><i class="ti ti-luggage bag-icon"></i> Check-In Baggage: <strong>@segments.CheckInBaggage.weight @segments.CheckInBaggage.weightUnit / Adult</strong></div>
                            </div>
                            if (segments.IsExtraBaggage > 0)
                            {
                                <div class="alert alert-info mt-3 d-flex justify-content-between align-items-center py-2 px-3 mb-0">
                                    <div class="small">
                                        Got excess baggage? Don’t stress, buy extra check-in baggage allowance for DEL–BLR at fab rates!
                                    </div>
                                    <a href="#" class="fw-semibold small text-primary text-decoration-none">ADD BAGGAGE</a>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info mt-3 d-flex justify-content-between align-items-center py-2 px-3 mb-0">
                                    <div class="small">
                                        <img src="~/Content/icon/extra-bag.png" style="width:25px;margin-right:5px;" />
                                        <span>
                                            Sorry, extra check-in baggage allowance details are currently not available from the airline for @segments.FromCity-@segments.ToCity.
                                        </span>
                                    </div>
                                </div>
                            }

                            <!-- Fare Rules Model -->
                            <div class="modal fade" id="fare-rule-@segCount" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
                                <div class="modal-dialog modal-dialog-centered modal-xl">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5>Fare Rules</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            @if (segments.fareRule != null && segments.fareRule.fareNotes != null && segments.fareRule.fareNotes.descriptions.Any())
                                            {
                                                var objRules = segments.fareRule.fareNotes.descriptions;
                                                foreach (var rule in objRules)
                                                {
                                                    <h5>@rule.descriptionType</h5>
                                                    <pre>@rule.text</pre>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- End Fare Rules Model -->
                            segCount++;
                        }
                    </div>
                }
            }

        </div>
    </div>

    <input type="hidden" name="offerId" value="@offerId" />
}

@helper Passangers(TravelPortal.web.Models.ViewModel.FlightSummaryVM objfareSummary)
