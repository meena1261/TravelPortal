            var txtAmount = document.getElementById("rechargeAmount").value;

            if (txtAmount == "" || parseInt(rechargeAmount) <= 1) {
                alert("Amount must be greater then zero !");
                return;
            }
            fetch('@Url.Action("CreateOrder", "Agent")', {
