                        fetch('@Url.Action("VerifyPayment", "Agent")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ paymentId: response.razorpay_payment_id, orderId: response.razorpay_order_id, signature: response.razorpay_signature }) // ₹500
                        }).then(res => res.json()).then(data => {
                            if (data.status > 0) {
                                Swal.fire({
                                    title: "Successfully",
                                    text: data.message,
                                    icon: "success"
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        location.reload();
                                    }
                                });
                               // location.reload();
