 <!-- Booking Header -->
<div class="card booking-header border-0">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <div>
                <h6>Flight Bookings</h6>
                <p class="fs-14">No of Booking : 0</p>
            </div>
        </div>
        <hr class="border" />
        <div class="row">
            <div class="col-md-3">
                <label class="form-label">Search</label>
                <input type="text" class="form-control" name="Searchtext" placeholder="Search..." />
            </div>
            <div class="col-md-3">
                <label class="form-label">Arrival City</label>
                <input type="text" class="form-control" name="ArrivalCity" placeholder="Search by Arrival city" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Origin City</label>
                <input type="text" class="form-control" name="OriginCity" placeholder="Search by Origin city" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Booking Date</label>
                <input type="date" class="form-control" name="fromDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Travel Date</label>
                <input type="date" class="form-control" name="toDate" />
            </div>
            <div class="col-md-3">
                <br />
                <button type="submit" class="btn btn-primary mt-2">Search</button>
            </div>
        </div>
    </div>
</div>
<!-- /Booking Header -->
<!-- Flight Booking List -->
