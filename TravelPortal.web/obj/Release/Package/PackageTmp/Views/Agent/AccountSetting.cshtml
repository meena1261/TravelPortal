@model UpdateProfileModel
@{
    string CurrentUrl = ViewBag.CurrentUrl;
}

<div class="card settings mb-0">
    <div class="card-header">
        <h6>Settings</h6>
    </div>
    <div class="card-body pb-1">
        <div class="settings-link d-flex align-items-center flex-wrap">
            <a href="@RouteConfig.UpdateProfile.ToPrefixApplicationURL()" class="@(CurrentUrl.Equals(RouteConfig.AgentSetting) || CurrentUrl.Equals(RouteConfig.UpdateProfile)?"active":"")"><i class="isax isax-user-octagon me-2"></i>Profile Settings</a>
            <a href="@RouteConfig.Security.ToPrefixApplicationURL()" class="@(CurrentUrl.Equals(RouteConfig.Security)?"active":"") ps-3"><i class="isax isax-shield-tick me-2"></i>Security</a>
        </div>
        @if (CurrentUrl.Equals(RouteConfig.AgentSetting) || CurrentUrl.Equals(RouteConfig.UpdateProfile))
        {
            @ProfileSetting();
        }
        else if (CurrentUrl.Equals(RouteConfig.Security))
        {
            @Security();
        }

    </div>
</div>

@helper ProfileSetting()
{
    using (Ajax.BeginForm("UpdateProfile", "Agent", null, new AjaxOptions { HttpMethod = "POST", OnSuccess = "fn_Success", OnFailure = "fn_Failure", OnBegin = "", OnComplete = "" }, new { enctype = "multipart/form-data" }))
    {
        <!-- Settings Content -->
        <div class="settings-content mb-3">
            <h6 class="fs-16 mb-3">Basic Information</h6>
            <div class="row gy-2">
                <div class="col-lg-12">
                    <div class="d-flex align-items-center">
                        <img src="~/Uploads/Profile/@Model.ProfilePhoto" alt="image" class="img-fluid avatar avatar-xxl br-10 flex-shrink-0 me-3" />
                        <div>
                            <p class="fs-14 text-gray-6 fw-normal mb-2">Recommended dimensions are typically 400 x 400 pixels.</p>
                            <div class="d-flex align-items-center">
                                <div class="me-2">
                                    <label class="upload-btn" for="UploadProfilePhoto">Upload</label>
                                    @Html.TextBoxFor(m => m.UploadProfilePhoto, new { @type = "file", @style = "display: none;" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div>
                        <label class="form-label">AgentID</label>
                        @Html.TextBoxFor(m => m.AgentID, new { @class = "form-control", @data_val = "true", @data_val_required = "Required", @disabled = "disabled" })
                    </div>
                    @Html.ValidationMessageFor(model => model.AgentID, "", new { @class = "text-danger" })
                </div>
                <div class="col-lg-6">
                    <div>
                        <label class="form-label">Name</label>
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control", @data_val = "true", @data_val_required = "Required" })
                    </div>
                    @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
                </div>
                <div class="col-lg-6">
                    <div>
                        <label class="form-label">Email</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", @data_val = "true", @data_val_required = "Required", @disabled = "disabled" })
                    </div>
                    @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                </div>
                <div class="col-lg-6">
                    <div>
                        <label class="form-label">Mobile No.</label>
                        @Html.TextBoxFor(m => m.Mobile, new { @class = "form-control", @data_val = "true", @data_val_required = "Required" })
                    </div>
                    @Html.ValidationMessageFor(model => model.Mobile, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>
        <div class="settings-content">
            <h6 class="fs-16 mb-3">Address Information</h6>
            <div class="row gy-2">
                <div class="col-lg-12">
                    <div>
                        <label class="form-label">Address</label>
                        @Html.TextAreaFor(m => m.Address, new { @class = "form-control", @data_val = "true", @data_val_required = "Required" })
                    </div>
                    @Html.ValidationMessageFor(model => model.Address, "", new { @class = "text-danger" })
                </div>
                <div class="col-lg-6">
                    <div>
                        <label class="form-label">Country</label>
                        @Html.TextBoxFor(m => m.Country, new { @class = "form-control", @data_val = "true", @data_val_required = "Required" })
                    </div>
                    @Html.ValidationMessageFor(model => model.Country, "", new { @class = "text-danger" })
                </div>
                <div class="col-lg-6">
                    <div>
                        <label class="form-label">State</label>
                        @Html.TextBoxFor(m => m.State, new { @class = "form-control", @data_val = "true", @data_val_required = "Required" })
                    </div>
                    @Html.ValidationMessageFor(model => model.State, "", new { @class = "text-danger" })
                </div>
                <div class="col-lg-6">
                    <div>
                        <label class="form-label">City</label>
                        @Html.TextBoxFor(m => m.City, new { @class = "form-control", @data_val = "true", @data_val_required = "Required" })
                    </div>
                    @Html.ValidationMessageFor(model => model.City, "", new { @class = "text-danger" })
                </div>
                <div class="col-lg-6">
                    <div>
                        <label class="form-label">Postal Code</label>
                        @Html.TextBoxFor(m => m.PostalCode, new { @class = "form-control", @data_val = "true", @data_val_required = "Required" })
                    </div>
                    @Html.ValidationMessageFor(model => model.PostalCode, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>
        <!-- /Settings Content-->

        <div class="d-flex align-items-center justify-content-center mt-4 mb-3">
            <button type="submit" class="btn btn-primary">Update</button>
        </div>
    }


    <script>
        function fn_Success(d) {
            if (d.status > 0) {

                Swal.fire({
                    title: "Successfully",
                    text: d.message,
                    icon: "success"
                }).then((result) => {
                    if (result.isConfirmed) {
                        location.reload();
                    }
                });
            } else {
                Swal.fire({
                    title: "failed",
                    text: d.message,
                    icon: "error"
                });
            }
        }
        function fn_Failure(d) {
            Swal.fire({
                title: "failed",
                text: "error",
                icon: "error"
            });
        }
    </script>
}

